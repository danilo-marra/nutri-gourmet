# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_DB=
POSTGRES_PASSWORD=

# Auto-generated from the variables above (dotenv-expand) — used in development
DATABASE_URL=postgres://$POSTGRES_USER:$POSTGRES_PASSWORD@$POSTGRES_HOST:$POSTGRES_PORT/$POSTGRES_DB

# In production/staging, override with a full connection string (e.g. Neon):
# DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# CA certificate for SSL connections in production (optional)
# POSTGRES_CA=

# =============================================================================
# EMAIL — SMTP (sending)
# =============================================================================
EMAIL_SMTP_HOST=localhost
EMAIL_SMTP_PORT=1025
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=

# =============================================================================
# EMAIL — HTTP (web UI, e.g. Mailcatcher in development)
# =============================================================================
EMAIL_HTTP_HOST=localhost
EMAIL_HTTP_PORT=1080

# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME=Nutri Gourmet
APP_EMAIL=no-reply@nutrigourmet.app.br

# Path used in activation email links (default: /activate)
ACTIVATION_PATH=/activate

# Path used in password recovery email links (default: /recovery)
PASSWORD_RECOVERY_PATH=/recovery

# Production URL (used by webserver.js for absolute links)
PRODUCTION_URL=https://www.nutrigourmet.app.br
