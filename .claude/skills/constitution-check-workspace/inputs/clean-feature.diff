@@ -45,4 +45,46 @@ describe("GET /api/v1/users/[username]", () => {
       });
     });
   });
+
+  describe("Authorized user", () => {
+    test("reading own profile returns 200 with filtered fields", async () => {
+      const created = await orchestrator.createUser({ username: "alice" });
+      await orchestrator.activateUser(created);
+      await orchestrator.addFeaturesToUser(created, ["read:user"]);
+      const sessionRow = await orchestrator.createSession(created.id);
+
+      const response = await fetch(
+        "http://localhost:3000/api/v1/users/alice",
+        { headers: { Cookie: `session_id=${sessionRow.token}` } },
+      );
+
+      expect(response.status).toBe(200);
+      const body = await response.json();
+      expect(body).toEqual({
+        id: body.id,
+        username: "alice",
+        features: ["read:user"],
+        created_at: body.created_at,
+        updated_at: body.updated_at,
+      });
+    });
+  });
+
+  describe("Unauthorized user", () => {
+    test("reading another user's profile returns 403", async () => {
+      const owner = await orchestrator.createUser({ username: "bob" });
+      const intruder = await orchestrator.createUser({ username: "mallory" });
+      await orchestrator.activateUser(intruder);
+      const sessionRow = await orchestrator.createSession(intruder.id);
+
+      const response = await fetch(
+        `http://localhost:3000/api/v1/users/${owner.username}`,
+        { headers: { Cookie: `session_id=${sessionRow.token}` } },
+      );
+
+      expect(response.status).toBe(403);
+      const body = await response.json();
+      expect(body.name).toBe("ForbiddenError");
+    });
+  });
 });
