 import { createRouter } from "next-connect";
 import controller from "infra/controller";
+import authentication from "models/authentication.js";
+import authorization from "models/authorization.js";
 import user from "models/user.js";

 const router = createRouter();

-router.get(getHandler);
+router.get(authentication.injectAuthenticatedUser, getHandler);
 router.patch(patchHandler);

 export default router.handler(controller.errorHandlers);

 async function getHandler(request, response) {
   const username = request.query.username;
+  const requesterUser = request.context.user;
+
+  if (!authorization.can(requesterUser, "read:user", { username })) {
+    return response.status(403).json({
+      name: "ForbiddenError",
+      message: "Você não tem permissão para ler este recurso.",
+      action: "Verifique se o usuário autenticado tem a feature 'read:user'.",
+      status_code: 403,
+    });
+  }
+
   const userFound = await user.findOneByUsername(username);
-  return response.status(200).json(userFound);
+  const filteredUser = authorization.filterOutput(
+    requesterUser,
+    "read:user",
+    userFound,
+  );
+  return response.status(200).json(filteredUser);
 }
diff --git a/tests/integration/api/v1/users/[username]/get.test.js b/tests/integration/api/v1/users/[username]/get.test.js
